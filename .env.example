# -------------------------------------------------------
# Buildrix — Environment Variables
# -------------------------------------------------------
# Copy this file to .env.local for local development
# and set the same variable in your Vercel project under:
#   Settings → Environment Variables → Production
# -------------------------------------------------------

# Base URL for the tasks API (no trailing slash)
# Local dev example:  http://localhost:3001/tasks
# Production example: https://api.mockapi.io/v1/<your-project-id>/tasks
# REQUIRED — the app will not load tasks if this is missing
VITE_API_BASE_URL=
